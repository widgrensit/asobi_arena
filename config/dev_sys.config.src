%% -*- mode: erlang;erlang-indent-level: 4;indent-tabs-mode: nil -*-

[
    {kernel, [
        {logger_level, debug},
        {logger, [
            {handler, default, logger_std_h, #{
                formatter =>
                    {nova_jsonlogger, #{
                        map_depth => 3,
                        term_depth => 50
                    }}
            }}
        ]}
    ]},
    {nova, [
        {use_stacktrace, true},
        {environment, dev},
        {cowboy_configuration, #{
            port => 8084
        }},
        {dev_mode, true},
        {bootstrap_application, asobi_arena},
        {json_lib, json}
    ]},
    {kura, [
        {repo, asobi_repo},
        {host, "localhost"},
        {port, 5436},
        {database, "asobi_arena_dev"},
        {user, "postgres"},
        {password, "postgres"},
        {pool_size, 10}
    ]},
    {shigoto, [
        {pool, asobi_repo}
    ]},
    {asobi, [
        {plugins, [
            {pre_request, nova_request_plugin, #{
                decode_json_body => true,
                parse_qs => true
            }},
            {pre_request, nova_cors_plugin, #{
                allow_origins => <<"*">>
            }},
            {pre_request, nova_correlation_plugin, #{}}
        ]},
        {game_modes, #{
            ~"arena" => asobi_arena_game
        }},
        {matchmaker, #{
            tick_interval => 1000,
            max_wait_seconds => 60
        }},
        {session, #{
            token_ttl => 900,
            refresh_ttl => 2592000
        }}
    ]},
    {asobi_arena, [
        {nova_apps, [asobi]}
    ]},
    {pg, [{scope, [nova_scope, arizona_pubsub]}]}
].
